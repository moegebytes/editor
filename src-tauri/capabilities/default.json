{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/next/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "opener:allow-open-path"
  ]
}
